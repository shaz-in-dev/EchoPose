menu "EchoPose Configuration"

    config WIFI_SSID
        string "Wi-Fi SSID"
        default "EchoPose_MESH"
        help
            SSID of the 2.4GHz Wi-Fi Access Point to connect to.

    config WIFI_PASSWORD
        string "Wi-Fi Password"
        default "echopose123"
        help
            Password for the Wi-Fi AP.

    config NODE_ID
        int "Node ID"
        default 0
        range 0 10
        help
            Unique ID for this node (0=Transmitter, 1-10=Receivers).

    config HOST_IP
        string "Aggregator Host IP"
        default "192.168.1.100"
        help
            IP address of the machine running the Rust Aggregator.

    config HOST_PORT
        int "Aggregator Host UDP Port"
        default 5005
        help
            UDP port the aggregator is listening on.

endmenu
