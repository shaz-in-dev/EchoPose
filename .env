# ==============================================================================
# EchoPose (formerly RF-Mesh) - Configuration
# ==============================================================================

# How many nodes should the mesh expect to discover before assuming full health?
EXPECTED_NODES=3

# ── Rust Aggregator ──────────────────
# Port to listen for raw UDP frames from ESP32s
AGGREGATOR_UDP_PORT=5005
# Port to host the REST API and WebSocket broadcast
AGGREGATOR_HTTP_PORT=3000
# How long to wait for nodes to sync before flushing the frame (in milliseconds)
AGGREGATOR_SYNC_WINDOW_MS=50
# Log level (trace, debug, info, warn, error)
RUST_LOG=info

# ── Python Inference ─────────────────
# The WS URI the Python engine connects to (must match AGGREGATOR_HTTP_PORT)
AGGREGATOR_WS_URI="ws://localhost:3000/ws"
# Port for the Python inference engine to broadcast processed skeletons
INFERENCE_WS_PORT=8765
# Force device type: "cuda", "mps", "cpu", or "auto"
INFERENCE_DEVICE="auto"
